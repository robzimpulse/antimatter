{
  "name": "antimatter",
  "displayName": "Antimatter",
  "description": "Unleash the power of AI coding on the go. Antimatter seamlessly syncs your VS Code workspace with your Android device in real-time.",
  "version": "1.0.0",
  "license": "MIT",
  "author": "Saif Mukhtar",
  "homepage": "https://saifmukhtar.dev",
  "publisher": "antimatter-saifmukhtar-dev",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "ai",
    "android",
    "sync",
    "antigravity",
    "mobile"
  ],
  "galleryBanner": {
    "color": "#0d0d0d",
    "theme": "dark"
  },
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/saifmukhtar/antimatter.git"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "antimatter.startAdapter",
        "title": "Antimatter: Start Adapter"
      },
      {
        "command": "antimatter.stopAdapter",
        "title": "Antimatter: Stop Adapter"
      },
      {
        "command": "antimatter.showConnectionInfo",
        "title": "Antimatter: Show Connection Info"
      }
    ],
    "configuration": {
      "title": "Antimatter",
      "properties": {
        "antimatter.port": {
          "type": "number",
          "default": 8765,
          "description": "WebSocket port for the Antimatter Gateway"
        },
        "antimatter.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the adapter when your workspace opens"
        }
      }
    }
  },
  "scripts": {
    "build": "node build.mjs",
    "watch": "node build.mjs --watch",
    "package": "vsce package",
    "lint": "tsc --noEmit",
    "test": "jest"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.80.0",
    "@types/ws": "^8.5.10",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^5.6.2"
  },
  "dependencies": {
    "ws": "^8.21.0"
  },
  "overrides": {
    "axios": "^1.7.9",
    "js-yaml": "^4.2.0"
  }
}
